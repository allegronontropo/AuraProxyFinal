{
  "name": "aura-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "AI Proxy Middleware — Security, Cost Control & Speed Optimization",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "db:migrate": "npm run prisma --workspace=@aura/db -- migrate dev",
    "db:generate": "npm run prisma --workspace=@aura/db -- generate",
    "db:studio": "npm run prisma --workspace=@aura/db -- studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "docker compose up -d && npm install && npm run db:generate && npm run db:migrate -- --name init",
    "postinstall": "npm run db:generate"
  },
  "devDependencies": {
    "shadcn": "^4.7.0",
    "turbo": "^2.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.2",
  "overrides": {
    "esbuild": "^0.28.0",
    "nodemailer": "^9.0.3",
    "postcss": "^8.5.10",
    "protobufjs": "^7.6.3"
  }
}
