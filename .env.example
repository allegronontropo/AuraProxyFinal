# ==============================
# Aura-Proxy Environment Variables
# ==============================

# Database (PostgreSQL + pgvector)
DATABASE_URL="postgresql://aura:aura_secret@localhost:5432/aura?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Proxy Server
PROXY_PORT=3000
PROXY_HOST=0.0.0.0

# Dashboard
DASHBOARD_PORT=3001

# Auth (NextAuth.js)
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"

# LLM Providers (add your keys)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
MISTRAL_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Embedding model for semantic cache
EMBEDDING_MODEL="text-embedding-3-small"
CACHE_SIMILARITY_THRESHOLD=0.95
